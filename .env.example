# Django
SECRET_KEY=django-insecure-замени-на-свой-ключ
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Threads OAuth (Meta Developers)
THREADS_ACCESS_TOKEN=
THREADS_API_BASE=https://graph.threads.net
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_REDIRECT_URI=https://your-domain.com/threads/oauth/callback/

# Авто-логин в Threads (Playwright, для /login команды бота)
THREADS_USERNAME=твой_instagram_username
THREADS_PASSWORD=твой_пароль

# Cloudflare Tunnel (опционально, для публичного HTTPS)
# Получить токен: https://one.dash.cloudflare.com → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=

# AI (Ollama — настроен автоматически в Docker)
OLLAMA_URL=http://ollama:11434/api/generate
OLLAMA_MODEL=llama3.1:8b
THREADS_DB_PATH=/data/posts.db
